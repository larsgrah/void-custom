pkgname=jmusic
version=0.1.0
revision=1
hostmakedepends="pkg-config gtk4-devel"
depends="gtk4"
nostrip=yes
short_desc="Music player with album grid UI and MPRIS support"
maintainer="larsgrah <void@lars.earth>"
license="GPL-3.0-only"
homepage="https://github.com/larsgrah/jmusic"

zig_ver=0.15.1
_arch="${XBPS_TARGET_MACHINE%%-*}"; : "${_arch:=$(uname -m)}"
case "$_arch" in
  x86_64)  zig_url="https://ziglang.org/download/${zig_ver}/zig-x86_64-linux-${zig_ver}.tar.xz" ;;
  aarch64) zig_url="https://ziglang.org/download/${zig_ver}/zig-aarch64-linux-${zig_ver}.tar.xz" ;;
  *) echo "unsupported arch: $_arch"; return 1 ;;
esac

tag="v${version}"
distfiles="
 https://github.com/larsgrah/jmusic/archive/refs/tags/${tag}.tar.gz
 ${zig_url}
"

checksum="011515a018a2f6f8a8c0f83b84d30e6efdadef04c5f7396eef2e29797d732d05
 c61c5da6edeea14ca51ecd5e4520c6f4189ef5250383db33d01848293bfafe05"

do_build() {
    if [ "${XBPS_TARGET_LIBC:-glibc}" = "musl" ]; then echo "upstream Zig binary needs glibc"; return 1; fi
    zdir="$(ls -1d "${wrksrc}"/zig-*linux-"${zig_ver}" 2>/dev/null | head -n1)"
    [ -n "$zdir" ] || { echo "Zig dir not found in wrksrc"; return 1; }
    export PATH="$zdir:$PATH"
    export ZIG_GLOBAL_CACHE_DIR="${wrksrc}/.zig-cache"
    zig version
    cd jmusic-${version}
    zig build -Doptimize=ReleaseSafe
}

do_install() {
    vbin jmusic-${version}/zig-out/bin/jmusic
    vinstall jmusic-${version}/assets/jmusic.desktop 644 usr/share/applications
}
